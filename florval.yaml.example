florval:
  schema_path: openapi.yaml
  output_directory: lib/api/generated

  model:
    serializer: freezed

  client:
    base_url_env: API_BASE_URL
    timeout: 30000
    retry:
      max_attempts: 3
      delay: 1000

  riverpod:
    enabled: true
    auto_invalidate: false
    # pagination:                          # Cursor-based pagination config
    #   - operation_id: listItems          # operationId of the paginated endpoint
    #     cursor_param: after              # Query parameter used as cursor
    #     next_cursor_field: nextCursor    # Response field for next page cursor
    #     items_field: items               # Response field for data array
